{
  "extends": "@higure/typescript-config/base.json",
  "compilerOptions": {
    "allowJs": true,
    "rootDir": "src",
    "esModuleInterop": true,
    "incremental": false,
    "outDir": "dist",
    "types": [
      "node"
    ]
  },
  "include": [
    "src",
    ".env"
  ],
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*spec.ts"
  ]
}