{
    "extends": "@higure/typescript-config/vite.json",
    "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "gql_generated/**/*"],
    "exclude": ["src/**/__tests__/*"],
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "paths": {
            "@/*": ["./src/*"]
        }
    }
}
